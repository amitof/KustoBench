{
  "description": "First 10 search phrases ordered alphabetically",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where SearchPhrase != \"\"\n| order by SearchPhrase asc\n| take 10",
  "sql": "SELECT SearchPhrase FROM hits WHERE SearchPhrase <> '' ORDER BY SearchPhrase LIMIT 10"
}
