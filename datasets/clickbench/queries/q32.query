{
  "description": "Top 10 WatchID + ClientIP by count (all rows)",
  "sql": "SELECT WatchID, ClientIP, COUNT(*) AS c, SUM(IsRefresh), AVG(ResolutionWidth) FROM hits GROUP BY WatchID, ClientIP ORDER BY c DESC LIMIT 10",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| summarize c = count(), sum(IsRefresh), avg(ResolutionWidth) by WatchID, ClientIP\n| top 10 by c desc"
}
