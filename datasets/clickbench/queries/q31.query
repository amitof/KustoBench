{
  "description": "Top 10 WatchID + ClientIP by count (non-empty phrase)",
  "sql": "SELECT WatchID, ClientIP, COUNT(*) AS c, SUM(IsRefresh), AVG(ResolutionWidth) FROM hits WHERE SearchPhrase <> '' GROUP BY WatchID, ClientIP ORDER BY c DESC LIMIT 10",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where SearchPhrase != \"\"\n| summarize hint.strategy=shuffle c = count(), sum(IsRefresh), avg(ResolutionWidth) by WatchID, ClientIP\n| top 10 by c desc"
}
