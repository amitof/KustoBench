{
  "description": "Top 10 search phrases by distinct users",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where SearchPhrase != \"\"\n| summarize hint.strategy=shuffle u = dcount(UserID) by SearchPhrase\n| top 10 by u desc",
  "sql": "SELECT SearchPhrase, COUNT(DISTINCT UserID) AS u FROM hits WHERE SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY u DESC LIMIT 10"
}
