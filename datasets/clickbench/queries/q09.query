{
  "description": "Top 10 regions with multiple aggregations",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| summarize sum(AdvEngineID), c = count(), avg(ResolutionWidth), dcount(UserID) by RegionID\n| top 10 by c desc",
  "sql": "SELECT RegionID, SUM(AdvEngineID), COUNT(*) AS c, AVG(ResolutionWidth), COUNT(DISTINCT UserID) FROM hits GROUP BY RegionID ORDER BY c DESC LIMIT 10"
}
