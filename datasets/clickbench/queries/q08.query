{
  "description": "Top 10 regions by distinct user count",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| summarize u = dcount(UserID) by RegionID\n| top 10 by u desc",
  "sql": "SELECT RegionID, COUNT(DISTINCT UserID) AS u FROM hits GROUP BY RegionID ORDER BY u DESC LIMIT 10"
}
