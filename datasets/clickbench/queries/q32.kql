// Q32: Top 25 search phrases for counter 62 in July 2013, descending.
hits
| where CounterID == 62
    and EventDate >= datetime(2013-07-01)
    and EventDate <= datetime(2013-07-31)
    and IsRefresh == 0
    and DontCountHits == 0
    and SearchPhrase != ""
| summarize c = count() by SearchPhrase
| top 25 by c desc
