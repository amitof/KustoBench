{
  "description": "First 10 non-empty search phrases ordered by time",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where SearchPhrase != \"\"\n| order by EventTime asc\n| take 10",
  "sql": "SELECT SearchPhrase FROM hits WHERE SearchPhrase <> '' ORDER BY EventTime LIMIT 10"
}
