{
  "description": "Top 10 mobile phone + model combinations",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where MobilePhoneModel != \"\"\n| summarize u = dcount(UserID) by MobilePhone, MobilePhoneModel\n| top 10 by u desc",
  "sql": "SELECT MobilePhone, MobilePhoneModel, COUNT(DISTINCT UserID) AS u FROM hits WHERE MobilePhoneModel <> '' GROUP BY MobilePhone, MobilePhoneModel ORDER BY u DESC LIMIT 10"
}
