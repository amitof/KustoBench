{
  "description": "Top 10 search phrases (Title contains Google)",
  "kql": "set maxmemoryconsumptionperiterator=17179869184;\nhits\n| where Title contains \"Google\" and not(URL contains \".google.\") and SearchPhrase != \"\"\n| summarize hint.strategy=shuffle min(URL), min(Title), c = count(), dcount(UserID) by SearchPhrase\n| top 10 by c desc",
  "sql": "SELECT SearchPhrase, MIN(URL), MIN(Title), COUNT(*) AS c, COUNT(DISTINCT UserID) FROM hits WHERE Title LIKE '%Google%' AND URL NOT LIKE '%.google.%' AND SearchPhrase <> '' GROUP BY SearchPhrase ORDER BY c DESC LIMIT 10"
}
