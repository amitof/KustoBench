// ClickBench "hits" table schema for Azure Data Explorer (Kusto).
// Based on the ClickBench analytical benchmark: https://benchmark.clickhouse.com/
//
// This .create table command defines the full 105-column web-analytics schema.

.create table hits (
    WatchID: long,
    JavaEnable: int,
    Title: string,
    GoodEvent: int,
    EventTime: datetime,
    EventDate: datetime,
    CounterID: int,
    ClientIP: int,
    RegionID: int,
    UserID: long,
    CounterClass: int,
    OS: int,
    UserAgent: int,
    URL: string,
    Referer: string,
    IsRefresh: int,
    RefererCategoryID: int,
    RefererRegionID: int,
    URLCategoryID: int,
    URLRegionID: int,
    ResolutionWidth: int,
    ResolutionHeight: int,
    ResolutionDepth: int,
    FlashMajor: int,
    FlashMinor: int,
    FlashMinor2: string,
    NetMajor: int,
    NetMinor: int,
    UserAgentMajor: int,
    UserAgentMinor: string,
    CookieEnable: int,
    JavascriptEnable: int,
    IsMobile: int,
    MobilePhone: int,
    MobilePhoneModel: string,
    Params: string,
    IPNetworkID: int,
    TraficSourceID: int,
    SearchEngineID: int,
    SearchPhrase: string,
    AdvEngineID: int,
    IsArtifical: int,
    WindowClientWidth: int,
    WindowClientHeight: int,
    ClientTimeZone: int,
    ClientEventTime: datetime,
    SilverlightVersion1: int,
    SilverlightVersion2: int,
    SilverlightVersion3: int,
    SilverlightVersion4: int,
    PageCharset: string,
    CodeVersion: int,
    IsLink: int,
    IsDownload: int,
    IsNotBounce: int,
    FUniqID: long,
    OriginalURL: string,
    HID: int,
    IsOldCounter: int,
    IsEvent: int,
    IsParameter: int,
    DontCountHits: int,
    WithHash: int,
    HitColor: string,
    LocalEventTime: datetime,
    Age: int,
    Sex: int,
    Income: int,
    Interests: int,
    Robotness: int,
    RemoteIP: int,
    WindowName: int,
    OpenerName: int,
    HistoryLength: int,
    BrowserLanguage: string,
    BrowserCountry: string,
    SocialNetwork: string,
    SocialAction: string,
    HTTPError: int,
    SendTiming: int,
    DNSTiming: int,
    ConnectTiming: int,
    ResponseStartTiming: int,
    ResponseEndTiming: int,
    FetchTiming: int,
    SocialSourceNetworkID: int,
    SocialSourcePage: string,
    ParamPrice: long,
    ParamOrderID: string,
    ParamCurrency: string,
    ParamCurrencyID: int,
    OpenstatServiceName: string,
    OpenstatCampaignID: string,
    OpenstatAdID: string,
    OpenstatSourceID: string,
    UTMSource: string,
    UTMMedium: string,
    UTMCampaign: string,
    UTMContent: string,
    UTMTerm: string,
    FromTag: string,
    HasGCLID: int,
    RefererHash: long,
    URLHash: long,
    CLID: int
)

// Disable inverted term indexing on all string columns
.alter column hits.Title policy encoding type='identifier'
.alter column hits.URL policy encoding type='identifier'
.alter column hits.Referer policy encoding type='identifier'
.alter column hits.FlashMinor2 policy encoding type='identifier'
.alter column hits.UserAgentMinor policy encoding type='identifier'
.alter column hits.MobilePhoneModel policy encoding type='identifier'
.alter column hits.Params policy encoding type='identifier'
.alter column hits.SearchPhrase policy encoding type='identifier'
.alter column hits.PageCharset policy encoding type='identifier'
.alter column hits.OriginalURL policy encoding type='identifier'
.alter column hits.HitColor policy encoding type='identifier'
.alter column hits.BrowserLanguage policy encoding type='identifier'
.alter column hits.BrowserCountry policy encoding type='identifier'
.alter column hits.SocialNetwork policy encoding type='identifier'
.alter column hits.SocialAction policy encoding type='identifier'
.alter column hits.SocialSourcePage policy encoding type='identifier'
.alter column hits.ParamOrderID policy encoding type='identifier'
.alter column hits.ParamCurrency policy encoding type='identifier'
.alter column hits.OpenstatServiceName policy encoding type='identifier'
.alter column hits.OpenstatCampaignID policy encoding type='identifier'
.alter column hits.OpenstatAdID policy encoding type='identifier'
.alter column hits.OpenstatSourceID policy encoding type='identifier'
.alter column hits.UTMSource policy encoding type='identifier'
.alter column hits.UTMMedium policy encoding type='identifier'
.alter column hits.UTMCampaign policy encoding type='identifier'
.alter column hits.UTMContent policy encoding type='identifier'
.alter column hits.UTMTerm policy encoding type='identifier'
.alter column hits.FromTag policy encoding type='identifier'
